# ==============================================================================
# AKRITI DIAGNOSTICS CENTER — ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' and fill in your real configuration values.
# IMPORTANT: Never commit the actual '.env' file containing secrets to Git!
# ==============================================================================

# --- Database Connection ---
# Local SQLite fallback is not recommended for production. Use PostgreSQL.
# In production, replace with your live database URL.
# Example: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/akriti_lab

# --- Redis Configuration ---
# Used for rate limiting, idempotency replay storage, and session caching.
# Format: redis://[[username]:[password]@]host[:port]/db_number
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication & Security ---
# Generate a strong 256-bit key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_your_own_secret_key_here_do_not_use_this_default
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- Email Notifications (Gmail SMTP / Standard SMTP) ---
# Notifications are built using provider-abstractions. Email is default.
# For Gmail, generate an 'App Password' from Google Account security settings.
MAIL_USERNAME=your_smtp_username@gmail.com
MAIL_PASSWORD=your_smtp_app_password
MAIL_FROM_NAME=Akriti Diagnostics Center
MAIL_FROM=your_smtp_username@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False

# --- Lab Details (Receipts, Billing & UPI Dynamic QR) ---
# UPI ID to generate local dynamic QR codes for payments (No API key needed)
LAB_UPI_VPA=yourupiid@bank
LAB_NAME=Akriti Diagnostics Center
LAB_ADDRESS=123, Diagnostic Lane, Medical Hub, City - 110001
LAB_PHONE=9876543210
LAB_GSTIN=07AAAAA0000A1Z2  # Leave blank if not registered

# --- Face Recognition Attendance Kiosk ---
# Match confidence threshold (0.0 to 1.0). 0.6 is a standard default for face matching.
FACE_MATCH_THRESHOLD=0.6
# Set to 'false' if PostgreSQL has pgvector extension installed.
# Set to 'true' if running on a basic PostgreSQL setup without pgvector (fallback to CPU/Python matching).
DISABLE_PGVECTOR=true

# --- Database Seeding ---
# Admin account credentials created automatically on initial database seeding/setup.
ADMIN_SEED_EMAIL=admin@akritidc.in
ADMIN_SEED_TEMP_PASSWORD=TemporaryStrongPassword123

# --- Deployment Environment ---
# 'development' enables auto-reload and CORS for local testing.
# 'production' enforces secure HTTPOnly cookies, HTTPS checks, and strict CORS.
ENVIRONMENT=development

# --- Server Host & Port ---
HOST=0.0.0.0
PORT=8000

# --- CORS (Cross-Origin Resource Sharing) ---
# Comma-separated list of allowed origins.
# In production, replace with your actual live domain (e.g., https://akritidc.in).
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
